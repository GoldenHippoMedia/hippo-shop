---
const features = [
  {
    title: 'Static pages, live data',
    body: 'Ship the HTML once. Prices, offer details, and order forms update from your data source — the page never needs to change.',
  },
  {
    title: 'Marketing owns the offer',
    body: 'Update a price or swap a destination’s order form without filing an engineering ticket. The next pageview reflects it.',
  },
  {
    title: 'One destination, many funnels',
    body: 'Reference the same <code class="font-mono text-[12px]">data-gh-destination</code> from multiple pages. One edit propagates across every funnel that points to it.',
  },
  {
    title: 'Works with your existing tooling',
    body: 'Custom HTML, page-builder export, hand-coded landing — the SDK reads the same data attributes everywhere. No framework required.',
  },
];
---
<section class="bg-gh-ink-50 px-8 py-16">
  <h2 class="font-display font-bold text-3xl text-center mb-2">Why use it</h2>
  <p class="text-sm text-gh-ink-500 text-center mb-10 max-w-[540px] mx-auto">
    Built for Golden Hippo funnel writers.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-3 max-w-[760px] mx-auto">
    {features.map((feature) => (
      <div class="bg-white border border-gh-ink-300 rounded-xl p-5 shadow-[0_1px_2px_rgba(15,17,21,0.04)]">
        <h3 class="font-display font-semibold text-sm mb-2">
          <Fragment set:html={feature.title} />
        </h3>
        <p class="text-sm text-gh-ink-500 leading-relaxed">
          <Fragment set:html={feature.body} />
        </p>
      </div>
    ))}
  </div>
</section>
