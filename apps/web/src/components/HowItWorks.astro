---
const steps = [
  {
    title: 'Drop the SDK script tag on your page',
    body: 'Add the script with your access key and brand. The SDK boots automatically and attaches <code class="font-mono text-[13px]">window.gh</code>.',
  },
  {
    title: 'Wrap your CTA in <code class="font-mono text-[13px]">data-gh-destination</code>',
    body: 'One destination per offer. Inside it, bind the price, the offer name, and the order form ID with <code class="font-mono text-[13px]">data-field</code> and <code class="font-mono text-[13px]">data-attr-*</code>.',
  },
  {
    title: 'Marketing edits the destination, the page updates',
    body: 'Change a price or swap an order form in your destination data — the next pageview reflects it. No PR, no deploy, no engineering ticket.',
  },
];
---
<section class="bg-white px-8 py-16">
  <h2 class="font-display font-bold text-3xl text-center mb-2">How it works</h2>
  <p class="text-sm text-gh-ink-500 text-center mb-10 max-w-[540px] mx-auto">
    Three steps, no build tooling required.
  </p>

  <div class="max-w-[640px] mx-auto">
    {steps.map((step, i) => (
      <div class={`flex gap-4 py-4 items-start ${i === 0 ? '' : 'border-t border-gh-ink-100'}`}>
        <div class="bg-gh-yellow-500 text-gh-ink-900 w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0">
          {i + 1}
        </div>
        <div>
          <h3 class="font-display font-semibold text-base mb-1">
            <Fragment set:html={step.title} />
          </h3>
          <p class="text-sm text-gh-ink-700">
            <Fragment set:html={step.body} />
          </p>
        </div>
      </div>
    ))}
  </div>
</section>
